RewriteEngine On
RewriteBase /

# 1. ALLOW THE BACKEND TO WORK (Don't redirect /backend/...)
RewriteRule ^backend/ - [L]

# 2. HANDLE REACT ROUTING (Fix for /admin)
# If a file or folder doesn't exist, send the request to index.html
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule . /index.html [L]
