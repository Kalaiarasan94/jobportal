# ==========================================================
# Malligai EPS Registration — Backend Environment Config
# Copy this file to .env and fill in your values
# ==========================================================

# MySQL Database Configuration
#
# IMPORTANT (shared hosting like Hostinger):
#   - DB_HOST is almost always "localhost" (or "127.0.0.1"). It is NOT your
#     database name. Setting DB_HOST to the database name causes:
#       SQLSTATE[HY000] [2002] php_network_getaddresses: getaddrinfo ... failed
#   - DB_NAME is the full database name shown in hPanel, e.g. u928398901_jcieps
#   - DB_USER is the full database user, e.g. u928398901_jciepsuser
#
# Local (XAMPP/dev) example:      DB_HOST=localhost  DB_USER=root  DB_NAME=epsjci
# Hostinger (production) example: DB_HOST=localhost  DB_USER=u928398901_...  DB_NAME=u928398901_jcieps
#DB_HOST=localhost
#DB_PORT=3306
#DB_USER=root
#DB_PASSWORD=
#DB_NAME=epsjci

#production db

DB_HOST=localhost
DB_PORT=3306
DB_NAME=u928398901_jcieps
DB_USER=u928398901_jcieps
DB_PASSWORD=Kirtheesh@2026


# Admin Credentials (change these before going live)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
# Any random string — changing it invalidates existing admin sessions
ADMIN_TOKEN_SALT=change-this-to-a-long-random-string

# Branding
ORG_NAME=Malligai EPS
EVENT_NAME=Malligai EPS Registration

# Registration fee shown on the payment step and printed on the ID card
REGISTRATION_FEE=2000

# Contact buttons on the registration page
# CONTACT_PHONE is dialled as-is; CONTACT_WHATSAPP must be digits only (country code + number)
CONTACT_PHONE=+917200783406
CONTACT_WHATSAPP=917200783406

# Uploads
MAX_UPLOAD_MB=8

# Server Configuration
APP_PORT=5000
APP_ENV=development
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
