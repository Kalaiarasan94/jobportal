RewriteEngine On

# NOTE: CORS preflight (OPTIONS) is handled inside PHP (config/cors.php) so the
# Access-Control-* headers are always set. Do not short-circuit OPTIONS here.

# ---- Extensionless API routes -------------------------------------------
# Public
RewriteRule ^api/config$                  api/config.php               [L,QSA]
RewriteRule ^api/register$                api/register.php             [L,QSA]

# Admin
RewriteRule ^api/admin/login$             api/admin/login.php          [L,QSA]
RewriteRule ^api/admin/registrations$     api/admin/registrations.php  [L,QSA]
RewriteRule ^api/admin/approve$           api/admin/approve.php        [L,QSA]
RewriteRule ^api/admin/image$             api/admin/image.php          [L,QSA]
RewriteRule ^api/admin/idcard$            api/admin/idcard.php         [L,QSA]
RewriteRule ^api/admin/export-excel$      api/admin/export-excel.php   [L,QSA]
RewriteRule ^api/admin/export-pdf$        api/admin/export-pdf.php     [L,QSA]

# ---- Protect sensitive paths --------------------------------------------
<FilesMatch "\.(env|env\.example)$">
    Require all denied
</FilesMatch>

RewriteRule ^config/  - [F,L]
RewriteRule ^lib/     - [F,L]
RewriteRule ^assets/fonts/ - [F,L]

# Uploaded payment screenshots are only served through payment-image.php,
# which checks the admin token first.
RewriteRule ^uploads/ - [F,L]

Options -Indexes
